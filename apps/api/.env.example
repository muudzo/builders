# Vaka API — environment template. Copy to `.env` and fill. NEVER commit the real `.env`.

NODE_ENV=development
PORT=3001

# Database. SQLite for local dev (zero infra). For production use a self-hosted
# PostgreSQL on Zimbabwe-based infra for data sovereignty (POTRAZ):
#   DATABASE_URL="postgresql://user:pass@localhost:5432/vaka?schema=public"
DATABASE_URL="file:./dev.db"

# Auth — generate strong secrets in production: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=604800      # seconds (7 days)

# CORS allowlist (frontend origin)
WEB_ORIGIN=http://localhost:5173

# Paynow — leave BLANK to run payments in SIMULATION mode (demo runs with no credentials).
# Fill with real values from the Paynow Developer Hub to go live.
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=http://localhost:3001/payments/paynow/callback
PAYNOW_RETURN_URL=http://localhost:5173/pay/return
